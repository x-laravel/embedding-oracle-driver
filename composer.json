{
    "name": "x-laravel/embedding-oracle-driver",
    "description": "Oracle 26ai vector similarity driver for x-laravel/embedding.",
    "keywords": ["laravel", "oracle", "embedding", "vector", "ai"],
    "license": "MIT",
    "authors": [
        {
            "name": "X-Adam",
            "email": "www@mehmetogmen.com.tr",
            "homepage": "https://mehmetogmen.com.tr"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "x-laravel/embedding": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "yajra/laravel-oci8": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "XLaravel\\Embedding\\Driver\\Oracle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XLaravel\\Embedding\\Driver\\Oracle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "XLaravel\\Embedding\\Driver\\Oracle\\OracleEmbeddingServiceProvider"
            ]
        }
    }
}
